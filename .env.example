# Site URL (production)
NEXT_PUBLIC_BASE_URL=https://www.swifthorseai.com

# Google Analytics 4 (optional — leave empty to disable)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Prompt optimizer / chat — OpenAI-compatible API (default: DeepSeek)
PROMPT_API_KEY=
PROMPT_API_BASE_URL=https://api.deepseek.com/v1
PROMPT_API_MODEL=deepseek-chat

# Alternative: OpenAI
# PROMPT_API_KEY=sk-...
# PROMPT_API_BASE_URL=https://api.openai.com/v1
# PROMPT_API_MODEL=gpt-4o-mini
